<Window x:Class="Laplace.Desktop.CreateArchiveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add to archive" Height="680" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <ListBox x:Name="InputList" Margin="0,0,16,0" Style="{StaticResource MaterialDesignListBox}" />
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Button Content="Add files" Click="AddFiles_Click" Margin="0,0,0,8" />
                <Button Content="Add folder" Click="AddFolder_Click" Margin="0,0,0,8" />
                <Button Content="Remove" Click="Remove_Click" Margin="0,0,0,8" Style="{StaticResource MaterialDesignOutlinedButton}" />
                <Button Content="Clear" Click="Clear_Click" Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Output -->
            <TextBlock Text="Archive" VerticalAlignment="Center" Grid.Row="0"/>
            <TextBox x:Name="OutputInput" Grid.Column="1" Grid.Row="0" Margin="8,0" TextChanged="OutputInput_TextChanged"/>
            <Button Content="Browse" Click="BrowseOutput_Click" Grid.Column="2" Grid.Row="0" Margin="8,0,0,0" Width="90"/>

            <!-- Mode -->
            <TextBlock Text="Mode" VerticalAlignment="Center" Grid.Row="1" Margin="0,8,0,0"/>
            <ComboBox x:Name="ModeCombo" Grid.Column="1" Grid.Row="1" Margin="8,8,8,0" SelectionChanged="ModeCombo_SelectionChanged" HorizontalAlignment="Left" Width="180"/>

            <!-- Block size -->
            <TextBlock Text="Block size" VerticalAlignment="Center" Grid.Row="2" Margin="0,8,0,0"/>
            <ComboBox x:Name="BlockSizeCombo" Grid.Column="1" Grid.Row="2" Margin="8,8,8,0" HorizontalAlignment="Left" Width="180" SelectionChanged="BlockSizeCombo_SelectionChanged"/>

            <!-- Solid -->
            <TextBlock Text="Solid" VerticalAlignment="Center" Grid.Row="3" Margin="0,8,0,0"/>
            <ComboBox x:Name="SolidCombo" Grid.Column="1" Grid.Row="3" Margin="8,8,8,0" HorizontalAlignment="Left" Width="180"/>

            <!-- Threads -->
            <TextBlock Text="Threads" VerticalAlignment="Center" Grid.Row="4" Margin="0,8,0,0"/>
            <TextBox x:Name="ThreadsInput" Grid.Column="1" Grid.Row="4" Margin="8,8,8,0" HorizontalAlignment="Left" Width="180"/>

            <!-- Password -->
            <TextBlock Text="Password" VerticalAlignment="Center" Grid.Row="5" Margin="0,8,0,0"/>
            <PasswordBox x:Name="PasswordInput" Grid.Column="1" Grid.Row="5" Margin="8,8,8,0" HorizontalAlignment="Left" Width="220"/>

            <!-- Confirm -->
            <TextBlock Text="Confirm" VerticalAlignment="Center" Grid.Row="6" Margin="0,8,0,0"/>
            <PasswordBox x:Name="ConfirmPasswordInput" Grid.Column="1" Grid.Row="6" Margin="8,8,8,0" HorizontalAlignment="Left" Width="220"/>

            <!-- Recovery -->
            <TextBlock Text="Recovery %" VerticalAlignment="Center" Grid.Row="7" Margin="0,8,0,0"/>
            <TextBox x:Name="RecoveryInput" Grid.Column="1" Grid.Row="7" Margin="8,8,8,0" HorizontalAlignment="Left" Width="180"/>

            <!-- Volume size -->
            <TextBlock Text="Volume size" VerticalAlignment="Center" Grid.Row="8" Margin="0,8,0,0"/>
            <ComboBox x:Name="VolumeSizeCombo" Grid.Column="1" Grid.Row="8" Margin="8,8,8,0" HorizontalAlignment="Left" Width="180"/>

            <!-- Checkboxes -->
            <CheckBox x:Name="VerifyCheck" Content="Verify after archiving" Grid.Column="1" Grid.Row="9" Margin="8,16,0,0" IsChecked="True"/>
            <CheckBox x:Name="EncryptCheck" Content="Encrypt" Grid.Column="2" Grid.Row="9" Margin="8,16,0,0"/>
            <CheckBox x:Name="HideNamesCheck" Content="Hide names" Grid.Column="2" Grid.Row="10" Margin="8,8,0,0" Checked="HideNamesCheck_Checked"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2">
            <Button Content="OK" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0" Width="100" />
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80" />
        </StackPanel>
    </Grid>
</Window>
