<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap desktop rescap">

  <Identity
    Name="{{PackageName}}"
    Publisher="{{Publisher}}"
    Version="{{PackageVersion}}" />

  <Properties>
    <DisplayName>{{DisplayName}}</DisplayName>
    <PublisherDisplayName>{{PublisherDisplayName}}</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>{{Description}}</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22631.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="LaplaceApp" Executable="laplace-gui.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="{{DisplayName}}"
        Description="{{Description}}"
        Square44x44Logo="Assets\Square44x44Logo.png"
        Square150x150Logo="Assets\Square150x150Logo.png"
        BackgroundColor="transparent" />
      <Extensions>
        <desktop:Extension Category="windows.fullTrustProcess" Executable="laplace-gui.exe" />
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="laplacearchive">
            <uap:DisplayName>Laplace Archive</uap:DisplayName>
            <uap:SupportedFileTypes>
              <uap:FileType>.lpc</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
